{
  "openapi": "3.0.0",
  "info": {
    "title": "API Documentation",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "Admin Auth",
      "description": "Operations related to admin authentication"
    },
    {
      "name": "Admin Dashboard",
      "description": "Operations related to admin dashboard functionalities"
    },
    {
      "name": "Admin Plan Management",
      "description": "Operations related to managing admin plans"
    }
  ],
  "paths": {
    "/admin/auth/login": {
      "post": {
        "tags": ["Admin Auth"],
        "summary": "Admin login",
        "description": "Authenticate admin and return a token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "username": "admin",
                "password": "admin123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "data": {
                    "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwidXNlcm5hbWUiOiJhZG1pbiIsImlhdCI6MTY4ODQyODg0OSwiZXhwIjoxNjg4NDMyNDQ5fQ.7n8sKj3m2v"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/admin/auth/logout": {
      "post": {
        "tags": ["Admin Auth"],
        "summary": "Admin logout",
        "description": "Logout admin and invalidate the token",
        "responses": {
          "200": {
            "description": "Successful logout",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "message": "Logged out successfully"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/admin/dashboard/stats": {
      "get": {
        "tags": ["Admin Dashboard"],
        "summary": "Get dashboard statistics",
        "description": "Retrieve various statistics for the admin dashboard",
        "responses": {
          "200": {
            "description": "Successful retrieval of statistics",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "data": {
                    "totalUsers": 1000,
                    "activeUsers": 800,
                    "revenue": 50000
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/admin/plans": {
      "get": {
        "tags": ["Admin Plan Management"],
        "summary": "Get all plans",
        "description": "Retrieve a list of all plans",
        "responses": {
          "200": {
            "description": "Successful retrieval of plans",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "data": [
                    {
                      "id": 1,
                      "name": "Basic Plan",
                      "price_monthly": 9.99,
                      "price_yearly": 99.99
                    },
                    {
                      "id": 2,
                      "name": "Standard Plan",
                      "price_monthly": 19.99,
                      "price_yearly": 99.99
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": ["Admin Plan Management"],
        "summary": "Create a new plan",
        "description": "Create a new plan with the provided details",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "name": "Pro Plan",
                "price_monthly": 29.99,
                "price_yearly": 299.99
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Plan created successfully",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "message": "Plan created successfully"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/admin/plans/{id}": {
      "put": {
        "tags": ["Admin Plan Management"],
        "summary": "Update a plan",
        "description": "Update the details of an existing plan",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "name": "Updated Pro Plan",
                "price_monthly": 39.99,
                "price_yearly": 399.99
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Plan updated successfully",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "message": "Plan updated successfully"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Plan not found"
          }
        }
      },
      "delete": {
        "tags": ["Admin Plan Management"],
        "summary": "Delete a plan",
        "description": "Delete an existing plan by its ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Plan deleted successfully",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "message": "Plan deleted successfully"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Plan not found"
          }
        }
      }
    },
    "/admin/features": {
      "get": {
        "tags": ["Admin Plan Management"],
        "summary": "Get all features",
        "description": "Retrieve a list of all features",
        "responses": {
          "200": {
            "description": "Successful retrieval of features",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "data": [
                    {
                      "id": 1,
                      "name": "Feature A",
                      "code": "feature_a"
                    },
                    {
                      "id": 2,
                      "name": "Feature B",
                      "code": "feature_b"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": ["Admin Plan Management"],
        "summary": "Create a new feature",
        "description": "Create a new feature with the provided details",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "name": "Feature C",
                "code": "feature_c"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feature created successfully",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "message": "Feature created successfully"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  }
}
